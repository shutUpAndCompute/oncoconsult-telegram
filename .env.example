# Telegram Platform Environment Configuration

# Bot configuration
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew-fg
TELEGRAM_PORT=3001

# Super admins (from .env - highest priority)
SUPER_ADMIN_CHAT_IDS=123456789,987654321
SUPER_ADMIN_PHONES=+919999999999,+918888888888

# Support staff
SUPPORT_PHONES=+917777777777,+916666666666

# Webhook security
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
PAYMENT_WEBHOOK_SECRET=your-payment-secret

# Data storage
DATA_DIR=./data

# Admin API key (for external API calls)
ADMIN_API_KEY=your-secure-admin-api-key